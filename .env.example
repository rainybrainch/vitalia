# ============================================
# Vitalia API Server 環境変数
# ============================================

# ========== AI プロバイダー選択 ==========
# 選択肢: gemini, openai, claude
AI_PROVIDER=gemini

# ========== Gemini API (Google) ==========
# 取得方法: https://ai.google.dev/
# コスト: 無料枠あり（月100万リクエストまで無料）
GEMINI_API_KEY=

# ========== OpenAI API (将来用) ==========
# 取得方法: https://platform.openai.com/
# コスト: $0.15 / 1M input tokens, $0.60 / 1M output tokens
# OPENAI_API_KEY=

# ========== Claude API - Anthropic (将来用) ==========
# 取得方法: https://console.anthropic.com/
# コスト: $3 / 1M input tokens, $15 / 1M output tokens
# CLAUDE_API_KEY=

# ========== サーバー設定 ==========
# ローカルサーバーのポート
PORT=5001

# ログレベル
LOG_LEVEL=info

# ============================================
# クイックスタート:
# ============================================
# 1. セットアップスクリプトを実行
#    $ npm run setup
#
# または手動セットアップ:
#
# 2. .env.example を .env にコピー
#    $ cp .env.example .env
#
# 3. Google AI Studio で API キーを取得
#    - https://ai.google.dev/
#    - 左メニュー「API keys」
#    - 「Create API key」でキー生成
#    - キーをコピー
#
# 4. .env を編集
#    - GEMINI_API_KEY= の後に取得したキーを貼り付け
#
# 5. npm install を実行
#    $ npm install
#
# 6. サーバーを起動
#    $ npm run dev
#
# 7. 別のターミナルで Live Server を起動
#    $ Open with Live Server (VSCode)
#    または
#    $ python -m http.server 5500
#
# ============================================

# ========== プロバイダー切り替えガイド ==========
#
# 現在の設定を確認:
#   $ npm run setup
#
# プロバイダーを Gemini から OpenAI に変更:
#   1. .env を編集
#   2. AI_PROVIDER=openai に変更
#   3. OPENAI_API_KEY= にキーを設定
#   4. サーバーを再起動: npm run dev
#
# ============================================
